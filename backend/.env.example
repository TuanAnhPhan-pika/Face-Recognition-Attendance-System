
ADMIN_TOKEN=EXAMPLE_ADMIN_TOKEN #change this to a secure random string in production

# Save captured images to disk?
SAVE_IMAGES=false

# Euclidean distance threshold for face matching
# Lower = stricter matching (0.0 - 1.0)
# Recommended: 0.5 - 0.6
EMBEDDING_THRESHOLD=0.6

# ===== DATABASE CONFIGURATION =====
# Currently using: SQL Server (configured below)
# Alternative: SQLite (set USE_SQL_SERVER=false)

USE_SQL_SERVER=true

# SQL Server Configuration
MSSQL_SERVER=YourServer\SQLEXPRESS #Change to your server name
MSSQL_DATABASE=AttendanceDB
MSSQL_TRUST=true
MSSQL_ENCRYPT=false



